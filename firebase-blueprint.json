{
  "entities": {
    "Volunteer": {
      "title": "Volunteer",
      "description": "A registered NGO volunteer with specific skills and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the volunteer" },
        "email": { "type": "string", "format": "email" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "List of skills (e.g., Medicine, Teaching, Construction)" },
        "role": { "type": "string", "enum": ["volunteer", "admin"] },
        "gender": { "type": "string", "enum": ["male", "female", "other", "prefer_not_to_say"] },
        "age": { "type": "number" },
        "address": { "type": "string" },
        "mobile": { "type": "string" },
        "yearsVolunteering": { "type": "number" }
      },
      "required": ["uid", "name", "email", "skills", "role"]
    },
    "Emergency": {
      "title": "Emergency Report",
      "description": "A reported community emergency needing attention.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterUid": { "type": "string" },
        "reporterName": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "assigned", "resolved"] },
        "requiredSkills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedByAi": { "type": "boolean" }
      },
      "required": ["reporterUid", "description", "location", "urgency", "status", "createdAt"]
    },
    "Task": {
      "title": "Assigned Task",
      "description": "An emergency assigned to a specific volunteer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "emergencyId": { "type": "string" },
        "assignedVolunteerUid": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["emergencyId", "assignedVolunteerUid", "status", "createdAt"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback or issue reports from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["issue", "improvement", "other"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/volunteers/{uid}": {
      "schema": "Volunteer",
      "description": "User profiles for volunteers."
    },
    "/emergencies/{emergencyId}": {
      "schema": "Emergency",
      "description": "Reports of emergencies in the community."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Assignments of emergencies to volunteers."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and issue reports."
    }
  }
}
