# ─────────────────────────────────────────────────────────────────────────────
# NGO Community Connect — Environment Variables Template
# Copy this file to `.env` and fill in your real values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth (used by the Express backend server) ──────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Frontend Variables (Vite — must be prefixed with VITE_) ────────────────
# Google OAuth client ID (same value as above, exposed to the browser)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase Web API key (from Firebase Console → Project Settings → General)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key

# Google Gemini AI API key (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── Backend Matchmaking Engine (optional — app works without it) ────────────
# Port the local Express matchmaking backend listens on (default: 5000)
# BACKEND_PORT=5000
